NEXT_PUBLIC_ROOT_DOMAIN="cursonube.com"

# Documento 2 (A2): apps/web y apps/api son dos servicios separados. El
# proxy same-origin (src/app/api/backend/[...path]/route.ts) reenvía acá
# server-side — el browser nunca le pega directo a la API (evita CORS y
# mantiene las cookies de sesión atadas al hostname del front, Documento 7).
API_BASE_URL="http://localhost:3000/api/v1"
