DATABASE_URL="postgresql://user:password@localhost:5432/cursonube?schema=public"

# Documento 16, sección 6: en producción viven en el secrets manager del
# proveedor de hosting, nunca en un .env versionado. Sin estas variables,
# session.service.ts usa defaults de desarrollo (no seguros para producción).
JWT_ACCESS_SECRET="cambiar-en-produccion"
JWT_REFRESH_SECRET="cambiar-en-produccion"
ENCRYPTION_KEY="cambiar-en-produccion"

# Documento 8, sección 2 — app de Mercado Pago (OAuth). Client ID/Secret
# identifican al software, no a una cuenta que reciba dinero.
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""
MP_REDIRECT_URI="http://localhost:3000/api/v1/pagos/mercado-pago/callback"
# Secreto de verificación de firma para los webhooks de ESTA aplicación
# (panel de Mercado Pago -> tu aplicación -> Webhooks -> "Firma secreta").
# Distinto de CURSONUBE_MP_WEBHOOK_SECRET (esa es la app de Billing propio).
MP_CHECKOUT_WEBHOOK_SECRET=""

# Documento 8, sección 6 — Billing propio de Cursonube (Cursonube -> Academia).
# A diferencia de MP_CLIENT_ID/SECRET (identifican al software para el OAuth
# del creador), esto es el access_token de la cuenta de Mercado Pago DE
# CURSONUBE MISMO — quien cobra acá es Cursonube, no un creador conectado.
CURSONUBE_MP_ACCESS_TOKEN=""
# Secreto de verificación de firma de webhooks (panel de Mercado Pago ->
# tu aplicación -> Webhooks -> "Firma secreta"). Sin esto no hay forma de
# confirmar que un webhook realmente vino de Mercado Pago (Documento 8, sección 4).
CURSONUBE_MP_WEBHOOK_SECRET=""

# Documento 18, sección 2 — email transaccional (Resend).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Cursonube <notificaciones@cursonube.com>"
