DATABASE_URL="postgresql://user:password@localhost:5432/cursonube?schema=public"

# Documento 16, sección 6: en producción viven en el secrets manager del
# proveedor de hosting, nunca en un .env versionado. Sin estas variables,
# session.service.ts usa defaults de desarrollo (no seguros para producción).
JWT_ACCESS_SECRET="cambiar-en-produccion"
JWT_REFRESH_SECRET="cambiar-en-produccion"
